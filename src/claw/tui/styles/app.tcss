/* Claw Code Agent TUI — Dark theme */

Screen {
    background: $surface;
}

/* Three-panel layout */
#main-container {
    layout: grid;
    grid-size: 2 1;
    grid-columns: 20 1fr;
    grid-rows: 1fr;
    height: 1fr;
}

/* Sidebar */
#sidebar {
    width: 100%;
    height: 100%;
    background: $panel;
    border-right: solid $primary-background;
    padding: 0 1;
}

#sidebar .nav-item {
    padding: 0 1;
    height: 1;
}

#sidebar .nav-item:hover {
    background: $accent;
}

#sidebar .nav-item.--active {
    background: $primary;
    color: $text;
}

#sidebar .section-header {
    color: $text-muted;
    padding: 1 0 0 0;
    text-style: bold;
}

#sidebar .status-line {
    color: $text-muted;
    padding: 0 1;
}

/* Chat area */
#chat-panel {
    height: 1fr;
    layout: vertical;
}

#message-list {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

#status-bar {
    height: 1;
    background: $primary-background;
    color: $text-muted;
    padding: 0 1;
    dock: bottom;
}

/* Messages */
.message {
    margin: 1 0;
    padding: 0 1;
}

.message.user {
    background: $boost;
    border: solid $primary;
    border-title-color: $primary;
}

.message.assistant {
    background: $surface;
    border: solid $secondary;
    border-title-color: $secondary;
}

.message.tool {
    background: $panel;
    border: dashed $warning;
    border-title-color: $warning;
    max-height: 8;
    overflow-y: auto;
}

/* Input area */
#input-container {
    dock: bottom;
    height: auto;
    max-height: 8;
    min-height: 3;
    background: $panel;
    border-top: solid $primary-background;
    padding: 0 1;
}

#input-box {
    height: auto;
    min-height: 1;
    max-height: 6;
}

#input-hint {
    height: 1;
    color: $text-muted;
    text-align: right;
}

/* Permission modal */
#permission-modal {
    align: center middle;
    width: 60;
    height: auto;
    max-height: 20;
    background: $surface;
    border: thick $warning;
    padding: 1 2;
}

#permission-modal .title {
    text-style: bold;
    color: $warning;
}

/* Progress indicators */
.phase-complete {
    color: $success;
}

.phase-active {
    color: $warning;
    text-style: bold;
}

.phase-pending {
    color: $text-muted;
}
