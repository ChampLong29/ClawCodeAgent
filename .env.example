# ============================================================
# Claw Code Agent — API Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#
# Choose ONE of the following profiles:
#   Profile A — Anthropic native API
#   Profile B — OpenAI-compatible API (vLLM, Ollama, LiteLLM, etc.)

# ============================================================
# Profile A: Anthropic native API
# ============================================================
# Use this for the official Anthropic API, or any proxy that
# speaks the Anthropic Messages protocol (MiniMax, etc.).

ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# For MiniMax / other proxies that use auth-token instead of api-key:
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-auth-token-here
# ANTHROPIC_MODEL=MiniMax-M2.7

# For DeepSeek (Anthropic-compatible endpoint):
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_API_KEY=sk-your-deepseek-key
# ANTHROPIC_MODEL=deepseek-v4-pro

# ============================================================
# Profile B: OpenAI-compatible API
# ============================================================
# Use this for self-hosted models via vLLM, Ollama, LiteLLM,
# or any service that exposes a /chat/completions endpoint.

# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=local-token
# OPENAI_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# Other common setups:
# vLLM:
#   OPENAI_BASE_URL=http://127.0.0.1:8000/v1
#   OPENAI_API_KEY=not-needed
#   OPENAI_MODEL=your-model-name
#
# Ollama:
#   OPENAI_BASE_URL=http://127.0.0.1:11434/v1
#   OPENAI_API_KEY=ollama
#   OPENAI_MODEL=qwen3-coder:30b
#
# LiteLLM proxy:
#   OPENAI_BASE_URL=http://127.0.0.1:4000/v1
#   OPENAI_API_KEY=sk-your-litellm-key
#   OPENAI_MODEL=claude-sonnet-4-6

# ============================================================
# Thinking / Reasoning Configuration
# ============================================================
# Controls extended thinking (chain-of-thought) for models that
# support it (Claude with extended thinking, DeepSeek, etc.)
#
# CLAW_THINKING_ENABLED — whether to enable thinking mode
#   "auto"  — (default) don't request thinking, but handle it if model returns it
#   "true"  — explicitly enable thinking in API requests
#   "false" — disable; strip thinking blocks from conversation history
# CLAW_THINKING_ENABLED=auto

# CLAW_THINKING_BUDGET — max tokens the model may spend on thinking (default: 10000)
#   Only used when CLAW_THINKING_ENABLED=true.
#   Higher = deeper reasoning but slower and more expensive.
# CLAW_THINKING_BUDGET=10000

# CLAW_THINKING_EFFORT — thinking intensity preset (default: medium)
#   "low"    — quick/shallow reasoning (budget_tokens = 4000)
#   "medium" — balanced (budget_tokens = 10000)
#   "high"   — deep reasoning for complex tasks (budget_tokens = 30000)
#   "max"    — maximum reasoning depth (budget_tokens = 60000)
#   If CLAW_THINKING_BUDGET is also set, it takes precedence over CLAW_THINKING_EFFORT.
# CLAW_THINKING_EFFORT=medium

# ============================================================
# Optional: defaults for chat sessions
# ============================================================
# CLAW_MAX_TURNS=100
# CLAW_TEMPERATURE=0.1
# CLAW_API_TIMEOUT=300
